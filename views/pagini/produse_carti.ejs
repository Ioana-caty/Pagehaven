        <!DOCTYPE html>
        <html lang="ro">

        <head>
            <meta name="description"
                content="Pagehaven - biblioteca virtuala gratuita cu carti de thriller, romance si fantasy.">
            <meta name="keywords" content="carti, biblioteca, gratuita, romance, fantasy, thriller, download">
            <link rel="stylesheet" href="/resurse/css/carti/produse_carti.css" type="text/css" />
            <link rel="stylesheet" href="/resurse/css/carti/filtre.css" type="text/css" />
            <script src="/resurse/js/produse_carti.js"></script>
            <title>Pagehaven - Cărți</title>
            <%- include("../fragmente/head") %>
        </head>

        <body>
            <%- include("../fragmente/header") %>

                <main>
                    <section id="filtre">
                        <h2>Filtrează cărțile</h2>
                        <div class="container-filtre row g-3">

                            <!-- TEXT: Title -->
                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="filtru-grup">
                                    <label for="inp-titlu">Titlu:</label>
                                    <input type="text" id="inp-titlu" class="form-control" placeholder="Căutare după titlu...">
                                </div>
                            </div>

                            <!--  DATALIST: Autor -->
                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="filtru-grup">
                                    <label for="inp-autor">Autor:</label>
                                    <input type="text" id="inp-autor" class="form-control" list="dl-autori" placeholder="Alege autorul...">
                                    <datalist id="dl-autori">
                                        <% if (locals.optiuniAutori) { 
                                            for (let a of locals.optiuniAutori) { %>
                                                <option value="<%= a.autor %>"></option>
                                        <% } } %>
                                    </datalist>
                                </div>
                            </div>

                            <!-- RANGE: Pages -->
                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="filtru-grup">
                                    <label for="inp-pagini">Număr pagini:</label>
                                    <% 
                                        let maxPagini=0; 
                                        if (locals.carti) { 
                                            for (let carte of locals.carti) { 
                                                if (carte.numar_pagini> maxPagini) {
                                                    maxPagini = carte.numar_pagini;
                                                }
                                            }
                                        }
                                    %>
                                    <div class="range-container">
                                    <span>0</span>
                                        <input type="range" id="inp-pagini" class="form-range" min="0" max="<%= maxPagini %>" value="<%= maxPagini %>"> 
                                        <span><%= maxPagini %>(<span id="info-range"><%= maxPagini %></span>)</span>
                                    </div>
                                </div>
                            </div>

                            <!-- RADIO_BUTTONS: Book Type -->
                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="filtru-grup">
                                    <p class="fw-bold mb-2">Gen:</p> 
                                    <div id="radio-gen" class="d-flex flex-wrap gap-2">
                                        <input type="radio" class="btn-check" id="i_radToate" name="gr_rad" value="toate" <%= !locals.query?.gen || locals.query.gen === 'toate' ? 'checked' : '' %> >
                                        <label class="btn btn-outline-secondary" for="i_radToate">Toate</label>
                                        
                                        <% if (locals.optiuniGenuri) { 
                                            for (let opt of locals.optiuniGenuri) { %>
                                            <input type="radio" class="btn-check" id="i_rad<%- opt.unnest %>" name="gr_rad" value="<%- opt.unnest %>" <%= locals.query?.gen === opt.unnest ? 'checked' : '' %> >
                                            <label class="btn btn-outline-secondary" for="i_rad<%- opt.unnest %>"><%- opt.unnest.charAt(0).toUpperCase() + opt.unnest.slice(1) %></label>
                                        <% } } %>
                                    </div>
                                </div>
                            </div>

                            <!-- DROPDOWN: Public -->
                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="filtru-grup">
                                    <label for="inp-public">Public țintă:</label>
                                    <select id="inp-public" class="form-select">
                                        <option value="toate" selected>Toate</option>
                                        <% if (locals.optiuniPublic) { 
                                            for (let opt of locals.optiuniPublic) { %>
                                                <option value="<%- opt.unnest %>"><%- opt.unnest.charAt(0).toUpperCase() + opt.unnest.slice(1) %></option>
                                        <% } } %>
                                    </select>
                                </div>
                            </div>

                            <!-- MULTISELECT: Source -->
                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="filtru-grup">
                                    <label for="inp-sursa">Sursa (Select multiplu):</label>
                                    <select id="inp-sursa" class="form-select" multiple size="3">
                                        <% if (locals.optiuniSurse) { 
                                            for (let opt of locals.optiuniSurse) { %>
                                                <option value="<%- opt.unnest %>"><%- opt.unnest.charAt(0).toUpperCase() + opt.unnest.replace('_', ' ').slice(1) %></option>
                                        <% } } %>
                                    </select>
                                </div>
                            </div>

                            <!-- Language -->
                            <div class="col-12 col-md-6 col-lg-3">
                                <div class="filtru-grup" id="filtru-limbi">
                                    <p class="fw-bold mb-2">Limbi (Checkbox group):</p>
                                    <div id="check-limbi" class="d-flex flex-wrap gap-2">
                                        <% if (locals.optiuniLimbi) { 
                                            for (let opt of locals.optiuniLimbi) { %>
                                                <input type="checkbox" class="btn-check" id="i_chck<%- opt.limba %>" name="gr_chck" value="<%- opt.limba %>" checked >
                                                <label class="btn btn-outline-secondary" for="i_chck<%- opt.limba %>"><%- opt.limba.charAt(0).toUpperCase() + opt.limba.slice(1) %></label>
                                        <% } } %>
                                    </div>
                                </div>
                            </div>

                            <!-- Description -->
                            <div class="col-12 col-lg-6">
                                <div class="filtru-grup">
                                    <div class="form-floating">
                                        <textarea id="inp-descriere" class="form-control" placeholder="Ex: magie, dragon, mister..." style="height: 100px"></textarea>
                                        <label for="inp-descriere">Descriere (cuvinte separate prin virgulă):</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div id="butoane-filtre"> 
                            
                            <div class="row-butoane">
                                <button id="sortCresc" class="btn btn-primary">
                                    <i class="bi bi-sort-numeric-down"></i> <span class="d-none d-md-inline">Sortare Ascendentă</span>
                                </button>
                                <button id="sortDescresc" class="btn btn-primary">
                                    <i class="bi bi-sort-numeric-up-alt"></i> <span class="d-none d-md-inline">Sortare Descendentă</span>
                                </button>
                            </div>

                            <div class="row-butoane">
                                <button id="calculare" class="btn btn-info">
                                    <i class="bi bi-calculator"></i> <span class="d-none d-md-inline">Calculare Pagini</span>
                                </button>
                            </div>

                            <div class="row-butoane">
                                <p id="p-suma">Sau apăsați Alt+"c" </p>
                            </div>

                            <div class="row-butoane">
                                <button id="filtrare" class="btn btn-primary">
                                    <i class="bi bi-filter"></i> <span class="d-none d-md-inline">Filtrează</span>
                                </button>
                                <button id="resetare" class="btn btn-secondary">
                                    <i class="bi bi-arrow-counterclockwise"></i> <span class="d-none d-md-inline">Resetează</span>
                                </button>
                            </div>

                        </div>
                    </section>


                    <section id="produse">
                        <h2>Explorează colecția noastră de cărți</h2>
                        <div class="grid-produse">
                            <% const zile_saptamana=['Luni', 'Marti' , 'Miercuri' , 'Joi' , 'Vineri' , 'Sambata' , 'Duminica' ];
                                const luni=['Ianuarie', 'Februarie' , 'Martie' , 'Aprilie' , 'Mai' , 'Iunie' , 'Iulie'
                                , 'August' , 'Septembrie' , 'Octombrie' , 'Noiembrie' , 'Decembrie' ]; function
                                formatareData(dataStr) { const data=new Date(dataStr); const zi=data.getDate(); let
                                indexZi=data.getDay(); let index=(indexZi===0) ? 6 : indexZi - 1; const
                                zi_saptamana=zile_saptamana[index]; const luna=luni[data.getMonth()]; const
                                an=data.getFullYear(); return `${zi} (${zi_saptamana}) / ${luna} / ${an}`; } %>
                                <% for (let carte of locals.carti) { %>
                                    <article class="produs <%- carte.gen %>" id="ent<%- carte.id %>"
                                        data-titlu="<%- carte.titlu %>" data-gen="<%- carte.gen %>"
                                        data-public="<%- carte.public_tinta %>" data-pagini="<%- carte.numar_pagini %>"
                                        data-sursa="<%- carte.sursa %>" data-limbi="<%- carte.limba %>"
                                        data-serie="<%- carte.serie %>" data-descriere="<%- carte.descriere %>"
                                        data-autor="<%- carte.autor %>">
                                        <h3 class="produs-titlu">
                                            <a href="/carte/<%- carte.id %>"><span class="val-titlu"><%- carte.titlu %></span></a>
                                        </h3>

                                        <div class="produs-wrapper">
                                            <div class="produs-tabel-container">
                                                <table class="produs-tabel">
                                                    <thead>
                                                        <tr>
                                                            <th>Autor</th>
                                                            <th>Pagini</th>
                                                            <th>Sursa</th>
                                                            <th>Public</th>
                                                            <th>Limbi</th>
                                                            <th>Serie</th>
                                                            <th>Data Adăugării</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <tr>
                                                            <td><span class="val-autor"><%- carte.autor %></span></td>
                                                            <td><span class="val-pagini"><%- carte.numar_pagini %></span></td>
                                                            <td><span class="val-sursa"><%- carte.sursa %></span></td>
                                                            <td><span class="val-public"><%- carte.public_tinta %></span></td>
                                                            <td><span class="val-limbi"><%- carte.limba %></span></td>
                                                            <td><span class="val-serie"><%- carte.serie ? 'Da' : 'Nu' %></span></td>
                                                            <td><time class="val-data"><%- formatareData(carte.data_adaugarii) %></time></td>
                                                        </tr>
                                                    </tbody>
                                                </table>
                                            </div>

                                            <figure class="produs-imagine">
                                                <a href="/carte/<%- carte.id %>"><img
                                                        src="/resurse/imagini/carti/<%- carte.imagine %>"
                                                        alt="[imagine <%- carte.titlu %>]" /></a>
                                            </figure>
                                        </div>

                                        <p class="produs-descriere"><span class="val-descriere"><%- carte.descriere %></span></p>

                                        <div class="produs-meta">
                                            <p class="produs-gen">Gen: <span class="val-gen"><%- carte.gen %></span></p>
                                        </div>
                                    </article>
                                    <% } %>
                        </div>
                    </section>
                </main>

                <%- include("../fragmente/footer") %>
        </body>

        </html>